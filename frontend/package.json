{
  "name": "mpt-usage-reporting-extension-ui",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build:code": "node esbuild.config.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:code && npm run build:types",
    "check": "tsc -p tsconfig.json --noEmit && eslint src --max-warnings=0",
    "format": "eslint src --fix",
    "watch:types": "tsc -p tsconfig.json --watch",
    "watch:code": "node esbuild.config.js --watch",
    "start": "npm-run-all --parallel watch:types watch:code",
    "test": "jest --runInBand"
  },
  "files": [
    "../static"
  ],
  "dependencies": {
    "@mpt-extension/sdk": "^0.0.7",
    "@mpt-extension/sdk-react": "^0.0.7",
    "@softwareone-platform/sdk-react-ui-v0": "^0.0.2",
    "esbuild-sass-plugin": "^3.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.4.1",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
